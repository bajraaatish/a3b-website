---
import Wordmark from "./Wordmark.astro";
import Button from "./Button.astro";
import { navLinks } from "../data/site";

/** Fixed, minimal navigation. Active state derived from the current path. */
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---
<nav class="nav" aria-label="Primary">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label="a3b — home">
      <Wordmark />
    </a>
    <ul class="nav__links">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[isActive(link.href) && "is-active"]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="nav__right">
      <button
        class="nav__theme"
        type="button"
        data-theme-toggle
        aria-label="Switch to dark theme"
        title="Toggle light / dark"
      >
        {/* Moon — shown in light mode (tap for dark). */}
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z"
            fill="currentColor"
          ></path>
        </svg>
        {/* Sun — shown in dark mode (tap for light). */}
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" fill="currentColor"></circle>
          <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7"></path>
          </g>
        </svg>
      </button>
      <a href="/contact" class="nav__cta">Book a brief</a>
      <button
        class="nav__burger"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span></span><span></span>
      </button>
    </div>
  </div>
  <div class="nav__drawer" id="nav-drawer">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[isActive(link.href) && "is-active"]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))
    }
    <Button href="/contact" variant="sage" chevron={false}>
      Book a 20-minute brief
    </Button>
  </div>
</nav>
