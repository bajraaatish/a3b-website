---
/**
 * AutoVideo
 * --------------------------------------------------------------
 * Autoplay + loop + muted video with a single custom pause/play
 * pill. No native controls. Apple-style frosted button positioned
 * via `controlSide` (right by default, left for the vertical demo).
 */
interface Props {
  src: string;
  poster?: string;
  /** "wide" = 16:9, "vertical" = 9:16 */
  ratio?: "wide" | "vertical";
  /** Which side the play/pause button sits on */
  controlSide?: "right" | "left";
  /** Extra class on the outer container */
  class?: string;
}
const {
  src,
  poster,
  ratio = "wide",
  controlSide = "right",
  class: cls,
} = Astro.props;
---
<div class:list={["autovid", `autovid--${ratio}`, `autovid--ctrl-${controlSide}`, cls]} data-autovid>
  <video
    class="autovid__video"
    src={src}
    poster={poster}
    autoplay
    loop
    muted
    playsinline
    preload="metadata"
  ></video>
  <button
    type="button"
    class="autovid__btn"
    data-autovid-btn
    aria-label="Pause video"
    aria-pressed="true"
  >
    <span class="autovid__icon autovid__icon--pause" aria-hidden="true">
      <span></span><span></span>
    </span>
    <span class="autovid__icon autovid__icon--play" aria-hidden="true"></span>
  </button>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-autovid]").forEach((root) => {
    const video = root.querySelector<HTMLVideoElement>(".autovid__video");
    const btn = root.querySelector<HTMLButtonElement>("[data-autovid-btn]");
    if (!video || !btn) return;

    /* Track whether the user explicitly paused. If they did, the
       IntersectionObserver shouldn't auto-resume when the video
       scrolls back into view. */
    let userPaused = false;

    const sync = () => {
      const paused = video.paused;
      root.classList.toggle("is-paused", paused);
      btn.setAttribute("aria-pressed", paused ? "false" : "true");
      btn.setAttribute("aria-label", paused ? "Play video" : "Pause video");
    };

    btn.addEventListener("click", () => {
      if (video.paused) {
        userPaused = false;
        video.play();
      } else {
        userPaused = true;
        video.pause();
      }
    });
    video.addEventListener("play", sync);
    video.addEventListener("pause", sync);
    sync();

    /* Pause when off-screen so the decoder isn't running while the
       user is reading another section — frees CPU/GPU on mobile,
       which was a big contributor to scroll jank when both demo
       videos were decoding simultaneously. */
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              if (!userPaused) video.play().catch(() => {});
            } else {
              if (!video.paused) video.pause();
            }
          }
        },
        { threshold: 0.2 }
      );
      io.observe(root);
    }
  });
</script>
